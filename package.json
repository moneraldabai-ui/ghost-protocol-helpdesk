{
  "name": "ghost-protocol",
  "version": "1.0.0",
  "description": "GHOST PROTOCOL — IT Intelligence Suite",
  "type": "module",
  "main": "electron/main.cjs",
  "author": "MONER INTELLIGENCE SYSTEMS",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "set CSC_IDENTITY_AUTO_DISCOVERY=false&& vite build && electron-builder",
    "build:installer": "set CSC_IDENTITY_AUTO_DISCOVERY=false&& vite build && electron-builder --win && iscc installer.iss",
    "build:inno": "iscc installer.iss",
    "electron:preview": "vite build && electron ."
  },
  "dependencies": {
    "@uiw/react-md-editor": "^4.1.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^11.3.0",
    "d3-geo": "^3.1.1",
    "exceljs": "^4.4.0",
    "framer-motion": "^11.5.4",
    "gsap": "^3.12.5",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.441.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "topojson-client": "^3.1.0",
    "world-atlas": "^2.0.2",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "electron": "^32.1.0",
    "electron-builder": "^25.0.5",
    "postcss": "^8.4.45",
    "tailwindcss": "^3.4.11",
    "vite": "^5.4.6",
    "wait-on": "^8.0.1"
  },
  "build": {
    "extends": "./electron-builder.config.cjs"
  }
}
